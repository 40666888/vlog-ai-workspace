# 本地开发可用 127.0.0.1；部署到 Render / Railway / 云服务器时建议改为 0.0.0.0
HOST=127.0.0.1
PORT=3000
NODE_ENV=development
AI_REQUEST_TIMEOUT_MS=45000
AI_RUN_MODE=local-dev

# 运行模式：
# local-dev       公开页面允许用户自己填写 API Key，适合最小可行上线方案
# server-managed  前端隐藏 API Key，只使用服务端环境变量中的 key

# 线上安全提示：
# 1. 公网部署时，默认不要把 mock fallback 当成真实结果
# 2. 如果使用 server-managed，请只把真实 key 放在服务端环境变量，不要写入前端页面
# 3. 如果使用 local-dev，用户在页面填写的 key 仅用于当前请求，默认不长期持久化

# OpenAI 官方
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI Compatible / DeepSeek / Qwen / GLM 等兼容接口
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_PATH_SUFFIX=

# MiniMax Native 原生接口
MINIMAX_NATIVE_API_KEY=
MINIMAX_NATIVE_MODEL=MiniMax-M2.7
MINIMAX_NATIVE_BASE_URL=https://api.minimaxi.com/v1

# 公开部署时建议：
# - local-dev：保留下面三项为空，由访问者在前端自己填写 key
# - server-managed：在部署平台环境变量中填写你要托管的 provider key

# live:check 默认会使用这些字段
LIVE_COMPAT_PRESET=minimax-compatible
LIVE_CHECK_PORT=3320
